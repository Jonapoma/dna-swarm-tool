# GenomicSwarm Environment Configuration
# Copy this file to .env and fill in your values

# ── Claude API (Anthropic) ──────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model for agent reasoning (sonnet is best balance of quality/cost)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Flask ───────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=true
SECRET_KEY=genomicswarm-dev-secret-change-in-prod

# ── Simulation limits ───────────────────────────────────────────────────────
# Maximum agents per simulation run (cost control)
MAX_AGENTS=1000
# Parallel Claude API calls (tune based on your rate limits)
SIM_WORKERS=10
